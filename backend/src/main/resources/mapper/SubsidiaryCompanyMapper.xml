<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.offerflow.mapper.SubsidiaryCompanyMapper">

    <resultMap id="SubsidiaryCompanyResultMap" type="com.offerflow.entity.SubsidiaryCompany">
        <id property="id" column="id"/>
        <result property="groupName" column="group_name"/>
        <result property="subsidiaryName" column="subsidiary_name"/>
        <result property="shortName" column="short_name"/>
        <result property="businessLine" column="business_line"/>
        <result property="intro" column="intro"/>
        <result property="status" column="status"/>
        <result property="sortNum" column="sort_num"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectActiveList" resultMap="SubsidiaryCompanyResultMap">
        SELECT id, group_name, subsidiary_name, short_name, business_line, intro, status, sort_num, create_time, update_time
        FROM subsidiary_company
        WHERE status = 1
        ORDER BY sort_num ASC, id ASC
    </select>

    <select id="selectById" resultMap="SubsidiaryCompanyResultMap">
        SELECT id, group_name, subsidiary_name, short_name, business_line, intro, status, sort_num, create_time, update_time
        FROM subsidiary_company
        WHERE id = #{id}
        LIMIT 1
    </select>

</mapper>
