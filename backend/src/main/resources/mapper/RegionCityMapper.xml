<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.offerflow.mapper.RegionCityMapper">

    <resultMap id="RegionCityResultMap" type="com.offerflow.entity.RegionCity">
        <id property="code" column="code"/>
        <result property="provinceCode" column="province_code"/>
        <result property="name" column="name"/>
        <result property="sortNum" column="sort_num"/>
    </resultMap>

    <select id="selectByProvinceCode" resultMap="RegionCityResultMap">
        SELECT code, province_code, name, sort_num
        FROM region_city
        WHERE province_code = #{provinceCode}
        ORDER BY sort_num ASC, code ASC
    </select>

    <select id="selectByCode" resultMap="RegionCityResultMap">
        SELECT code, province_code, name, sort_num
        FROM region_city
        WHERE code = #{code}
        LIMIT 1
    </select>

</mapper>
