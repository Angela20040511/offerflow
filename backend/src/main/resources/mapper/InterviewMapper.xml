<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.offerflow.mapper.InterviewMapper">

    <resultMap id="InterviewResultMap" type="com.offerflow.entity.Interview">
        <id property="id" column="id"/>
        <result property="applicationId" column="application_id"/>
        <result property="roundNum" column="round_num"/>
        <result property="interviewTime" column="interview_time"/>
        <result property="interviewer" column="interviewer"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByApplicationId" resultMap="InterviewResultMap">
        SELECT
            id,
            application_id,
            round_num,
            interview_time,
            interviewer,
            status,
            remark,
            create_time,
            update_time
        FROM interview_record
        WHERE application_id = #{applicationId}
        ORDER BY round_num ASC, id ASC
    </select>

    <insert id="insertInterview" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO interview_record
        (
            application_id,
            round_num,
            interview_time,
            interviewer,
            status,
            remark,
            create_time,
            update_time
        )
        VALUES
        (
            #{applicationId},
            #{roundNum},
            #{interviewTime},
            #{interviewer},
            #{status},
            #{remark},
            NOW(),
            NOW()
        )
    </insert>

    <update id="updateInterviewStatus">
        UPDATE interview_record
        SET
            status = #{status},
            remark = #{remark},
            update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>