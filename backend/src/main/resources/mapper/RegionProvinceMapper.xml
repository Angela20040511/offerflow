<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.offerflow.mapper.RegionProvinceMapper">

    <resultMap id="RegionProvinceResultMap" type="com.offerflow.entity.RegionProvince">
        <id property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="sortNum" column="sort_num"/>
    </resultMap>

    <select id="selectAll" resultMap="RegionProvinceResultMap">
        SELECT code, name, sort_num
        FROM region_province
        ORDER BY sort_num ASC, code ASC
    </select>

</mapper>
