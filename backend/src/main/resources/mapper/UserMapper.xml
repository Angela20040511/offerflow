<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.offerflow.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.offerflow.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="BaseUserColumns">
        id, username, password, role, email, phone, avatar, status, create_time, update_time
    </sql>

    <select id="selectByUsernameAndRole" resultMap="UserResultMap">
        SELECT
        <include refid="BaseUserColumns"/>
        FROM sys_user
        WHERE username = #{username}
          AND role = #{role}
          AND status = 1
        LIMIT 1
    </select>

    <select id="selectById" resultMap="UserResultMap">
        SELECT
        <include refid="BaseUserColumns"/>
        FROM sys_user
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByUsername" resultMap="UserResultMap">
        SELECT
        <include refid="BaseUserColumns"/>
        FROM sys_user
        WHERE username = #{username}
        LIMIT 1
    </select>

    <insert id="insertUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user
        (
            username,
            password,
            role,
            email,
            phone,
            avatar,
            status,
            create_time,
            update_time
        )
        VALUES
        (
            #{username},
            #{password},
            #{role},
            #{email},
            #{phone},
            #{avatar},
            #{status},
            NOW(),
            NOW()
        )
    </insert>

</mapper>